{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Infinity Board / 桌遊大師 遊戲模組 Schema",
  "type": "object",
  "required": ["gameName", "players", "tokens", "actions", "rules", "turn"],
  "properties": {
    "gameName": { 
      "type": "object", 
      "properties": { 
        "zh": { "type": "string" }, 
        "en": { "type": "string" } 
      }, 
      "required": ["zh","en"] 
    },
    "players": { 
      "type": "array", 
      "items": { 
        "type": "object", 
        "required": ["id","name","tokens","score"], 
        "properties": { 
          "id": {"type":"string"}, 
          "name":{"type":"string"}, 
          "tokens":{"type":"array","items":{"type":"string"}}, 
          "score":{"type":"integer","minimum":0} 
        } 
      } 
    },
    "tokens": { 
      "type":"array", 
      "items": { 
        "type": "object", 
        "required":["id","name","type"], 
        "properties": { 
          "id":{"type":"string"}, 
          "name":{"type":"string"}, 
          "type":{"type":"string","enum":["resource","card","dice","custom"]}, 
          "properties":{"type":"object","additionalProperties":true} 
        } 
      } 
    },
    "actions": { 
      "type":"array", 
      "items": { 
        "type": "object", 
        "required":["id","name","parameters","effect"], 
        "properties": { 
          "id":{"type":"string"}, 
          "name":{"type":"string"}, 
          "parameters":{"type":"array","items":{"type":"string"}}, 
          "effect":{"type":"string"} 
        } 
      } 
    },
    "rules": { 
      "type":"array",
      "items": { 
        "type":"object",
        "required":["id","trigger","condition","action"], 
        "properties": { 
          "id":{"type":"string"}, 
          "trigger":{"type":"string","enum":["onActionEnd","onTurnEnd","onObjectChange"]}, 
          "condition":{"type":"object","required":["type"],"properties":{"type":{"type":"string"},"tokenId":{"type":"string"},"count":{"type":"integer","minimum":0}}, "additionalProperties":true}, 
          "action":{"type":"object","required":["type"],"properties":{"type":{"type":"string"},"playerId":{"type":"string"}}, "additionalProperties":true} 
        } 
      } 
    },
    "turn": { 
      "type":"object",
      "required":["currentPlayerId","actionsPerTurn"], 
      "properties":{
        "currentPlayerId":{"type":"string"}, 
        "actionsPerTurn":{"type":"integer","minimum":1}
      } 
    }
  },
  "additionalProperties": false
}

